{
  "manifest_version": 3,
  "name": "R-Searcher",
  "version": "2.0.0",
  "description": "Smart explain & summarize any article. AI picks the best format automatically.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "48": "R48.png",
    "128": "R128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "R48.png",
      "128": "R128.png"
    }
  },
  "commands": {
    "smart-explain": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "What's this? - Smart Explain"
    },
    "smart-analyze": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Read full page"
    },
    "copy-last": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Copy last result to clipboard"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "i18n.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}

